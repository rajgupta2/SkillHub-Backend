{
  "compilerOptions": {
    "target": "es2020",
    "module": "commonjs",
    "moduleResolution": "Node",
    "allowSyntheticDefaultImports": true,
    "rootDir": ".",
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": false,
    //"allowImportingTsExtensions":true,
    //"noImplicitAny": true,
    "sourceMap": true,  //it will use to generates .js.map files
    "baseUrl": "./",
  },
  "include": ["src","generated/prisma","prisma.config.ts"],
  "exclude": ["node_modules"]
}